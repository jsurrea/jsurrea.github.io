---
import '../styles/global.css';
import { GITHUB_USER } from '../config';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  /** Person's full name for the JSON-LD schema (from profile YAML). */
  personName?: string;
  /** Primary job title for the JSON-LD schema (from profile YAML). */
  personJobTitle?: string;
  /** sameAs URLs for the JSON-LD schema (social profile URLs from the YAML). */
  sameAs?: string[];
}

const {
  title = `${GITHUB_USER} — Software Engineer`,
  description = 'Software engineer, AI researcher, and open-source builder.',
  lang = 'en',
  personName = GITHUB_USER,
  personJobTitle = 'Software Engineer',
  sameAs = [`https://github.com/${GITHUB_USER}`],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og/default.png', Astro.site);

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: personName,
  url: `https://${GITHUB_USER}.github.io`,
  image: `https://github.com/${GITHUB_USER}.png`,
  sameAs,
  jobTitle: personJobTitle,
  alumniOf: 'Universidad de los Andes',
  knowsAbout: ['Machine Learning', 'Computer Vision', 'Full-Stack Development', 'Cloud Architecture'],
};
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="en" href={new URL('/', Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(person)} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
    <style>
      .skip-link {
        position: absolute;
        top: -100%;
        left: 0;
        background: var(--accent-primary);
        color: white;
        padding: 0.5rem 1rem;
        z-index: 9999;
        text-decoration: none;
      }
      .skip-link:focus {
        top: 0;
      }
    </style>
  </body>
</html>
