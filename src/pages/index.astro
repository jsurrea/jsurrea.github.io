---
import BaseLayout from '../layouts/Base.astro';
import { load as yamlLoad } from 'js-yaml';
import { fetchGitHubReposEnriched, fetchGitHubOrg } from '../lib/github';
import type { Profile } from '../lib/profile';
import { GITHUB_USER, PROFILE_URL, CV_URL, ORG_LOGINS, HERO_ROLES, ORG_DESCRIPTIONS } from '../config';

// Fetch and parse profile YAML at build time
let profile: Profile;
try {
  const res = await fetch(PROFILE_URL);
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const text = await res.text();
  profile = yamlLoad(text) as Profile;
} catch (e) {
  console.warn('Failed to fetch profile YAML:', e);
  profile = {
    basics: {
      name: GITHUB_USER,
      label: 'Software Engineer',
      email: '',
      phone: '',
      url: `https://${GITHUB_USER}.github.io/`,
      summary: '',
      profiles: [],
    },
  };
}

const { basics, education, work, publications, volunteer, awards, certificates, skills } = profile;

// Fetch GitHub repos
let repos: Awaited<ReturnType<typeof fetchGitHubReposEnriched>> = [];
try {
  repos = await fetchGitHubReposEnriched();
} catch (e) {
  console.warn('Failed to fetch GitHub repos:', e);
}

// Fetch GitHub orgs
interface OrgData {
  login: string;
  description: string | null;
  avatar_url: string;
  html_url: string;
  pagesUrl: string;
}
const orgs: OrgData[] = [];
for (const login of ORG_LOGINS) {
  try {
    const org = await fetchGitHubOrg(login);
    orgs.push({
      login,
      description: org.description,
      avatar_url: org.avatar_url,
      html_url: `https://github.com/${login}`,
      pagesUrl: `https://${login.toLowerCase()}.github.io/`,
    });
  } catch (e) {
    console.warn(`Failed to fetch org ${login}:`, e);
  }
}

// Format date helpers
function fmtYearMonth(dateStr?: string | null): string {
  if (!dateStr) return '';
  const iso = dateStr.match(/^\d{4}-\d{2}$/) ? dateStr + '-01' : dateStr;
  const d = new Date(iso + 'T00:00:00');
  if (isNaN(d.getTime())) return dateStr;
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

const roles = HERO_ROLES;
---

<BaseLayout
  lang="en"
  title={`${basics.name} — ${basics.label}`}
  description={basics.summary}
  personName={basics.name}
  personJobTitle={basics.label}
  sameAs={basics.profiles.map((p) => p.url)}
>
  <main id="main-content">
    <!-- Navigation -->
    <nav class="nav" aria-label="Main navigation">
      <div class="nav-inner">
        <a href="/" class="nav-logo">{GITHUB_USER}</a>
        <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <div class="nav-links" id="nav-links">
          {work && work.length > 0 && <a href="#experience">Experience</a>}
          {education && education.length > 0 && <a href="#education">Education</a>}
          {publications && publications.length > 0 && <a href="#publications">Research</a>}
          {skills && <a href="#skills">Skills</a>}
          {awards && awards.length > 0 && <a href="#awards">Awards</a>}
          <a href="#open-source">Open Source</a>
          <a href="#projects">Projects</a>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero" aria-label="Introduction">
      <div class="hero-particles" aria-hidden="true" id="hero-particles"></div>
      <div class="hero-inner">
        <div class="hero-text">
          <p class="hero-greeting">Hi, I'm</p>
          <h1 class="hero-name">
            {basics.name.split(' ').slice(0, 2).join(' ')}<br />
            {basics.name.split(' ').slice(2).join(' ')}
          </h1>
          <div class="hero-roles" aria-live="polite">
            <span class="typewriter" id="typewriter">{basics.label}</span>
          </div>
          <p class="hero-description">{basics.summary}</p>
          <div class="hero-ctas">
            <a href="#projects" class="btn btn-primary">View My Work</a>
            <a href={CV_URL} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
              Download CV
            </a>
          </div>
          <div class="hero-social">
            {basics.profiles.map((p) => (
              <a
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={p.network}
                class="hero-social-link"
              >
                {p.network}
              </a>
            ))}
            <a href={`mailto:${basics.email}`} aria-label="Email" class="hero-social-link">Email</a>
          </div>
        </div>
        <div class="hero-image">
          <div class="hero-image-ring" aria-hidden="true"></div>
          <img
            src={`https://github.com/${GITHUB_USER}.png`}
            alt={basics.name}
            width="300"
            height="300"
            loading="eager"
          />
        </div>
      </div>
      <div class="hero-scroll-hint" aria-hidden="true">
        <span class="scroll-indicator"></span>
      </div>
    </section>

    <!-- Experience Section -->
    {work && work.length > 0 && (
      <section id="experience" class="section" aria-label="Work experience">
        <div class="container">
          <h2 class="section-heading">
            <span class="section-number">01</span>
            Experience
          </h2>
          <div class="timeline">
            {work.map((job) => (
              <article class="timeline-item">
                <div class="timeline-dot" aria-hidden="true"></div>
                <div class="timeline-content">
                  <div class="timeline-header">
                    <div class="timeline-title-row">
                      <h3>{job.position}</h3>
                      {job.note && <span class="job-note">{job.note}</span>}
                    </div>
                    <a href={job.url} target="_blank" rel="noopener noreferrer" class="company-name">
                      {job.name}
                    </a>
                  </div>
                  <div class="timeline-meta">
                    {job.type && <span class={`badge badge-type badge-${job.type.replace(/\s+/g, '-')}`}>{job.type}</span>}
                    <time>
                      {fmtYearMonth(job.startDate)} — {job.endDate ? fmtYearMonth(job.endDate) : 'Present'}
                    </time>
                    {job.location && <span class="location-tag">📍 {job.location}</span>}
                  </div>
                  <ul class="highlights-list">
                    {job.highlights.map((h: string) => (
                      <li>{h}</li>
                    ))}
                  </ul>
                  {job.stack && job.stack.length > 0 && (
                    <div class="stack-tags">
                      {job.stack.map((s: string) => (
                        <span class="tag">{s}</span>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Education Section -->
    {education && education.length > 0 && (
      <section id="education" class="section section-alt" aria-label="Education">
        <div class="container">
          <h2 class="section-heading">
            <span class="section-number">02</span>
            Education
          </h2>
          <div class="timeline">
            {education.map((edu) => (
              <article class="timeline-item">
                <div class="timeline-dot timeline-dot-edu" aria-hidden="true"></div>
                <div class="timeline-content">
                  <div class="timeline-header">
                    <h3>{edu.studyType} in {edu.area}</h3>
                    <a href={edu.url} target="_blank" rel="noopener noreferrer" class="company-name">
                      {edu.institution}
                    </a>
                  </div>
                  <div class="timeline-meta">
                    <time>
                      {fmtYearMonth(edu.startDate)} — {edu.endDate ? fmtYearMonth(edu.endDate) : 'Present'}
                    </time>
                    {edu.location && <span class="location-tag">📍 {edu.location}</span>}
                  </div>
                  <div class="edu-honors">
                    {edu.honor && <span class="edu-honor-badge">{edu.honor}</span>}
                    {edu.gpa && <span class="edu-gpa">GPA: {edu.gpa}</span>}
                  </div>
                  {edu.highlights && edu.highlights.length > 0 && (
                    <ul class="highlights-list">
                      {edu.highlights.map((h: string) => (
                        <li>{h}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Publications Section -->
    {publications && publications.length > 0 && (
      <section id="publications" class="section" aria-label="Publications">
        <div class="container">
          <h2 class="section-heading">
            <span class="section-number">03</span>
            Research & Publications
          </h2>
          <div class="publications-list">
            {publications.map((pub) => (
              <article class="pub-card">
                <div class="pub-header">
                  <span class="ieee-badge">IEEE {pub.year}</span>
                  <span class="pub-venue">{pub.venue}</span>
                </div>
                <h3>{pub.title}</h3>
                <p class="pub-authors">{pub.authors}</p>
                <div class="pub-links">
                  {pub.paperUrl && (
                    <a href={pub.paperUrl} target="_blank" rel="noopener noreferrer" class="pub-link">
                      📄 Paper
                    </a>
                  )}
                  {pub.codeUrl && (
                    <a href={pub.codeUrl} target="_blank" rel="noopener noreferrer" class="pub-link">
                      Code
                    </a>
                  )}
                  {pub.demoUrl && (
                    <a href={pub.demoUrl} target="_blank" rel="noopener noreferrer" class="pub-link">
                      🚀 Demo
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Volunteer Section -->
    {volunteer && volunteer.length > 0 && (
      <section id="volunteer" class="section section-alt" aria-label="Volunteer">
        <div class="container">
          <h2 class="section-heading">
            <span class="section-number">04</span>
            Volunteer
          </h2>
          <div class="timeline">
            {volunteer.map((v) => (
              <article class="timeline-item">
                <div class="timeline-dot" aria-hidden="true"></div>
                <div class="timeline-content">
                  <div class="timeline-header">
                    <h3>{v.role}</h3>
                    <a href={v.url} target="_blank" rel="noopener noreferrer" class="company-name">
                      {v.organization}
                    </a>
                  </div>
                  <div class="timeline-meta">
                    <time>
                      {fmtYearMonth(v.startDate)} — {v.endDate ? fmtYearMonth(v.endDate) : 'Present'}
                    </time>
                  </div>
                  <p class="volunteer-summary">{v.summary}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Skills Section -->
    {skills && (
      <section id="skills" class="section" aria-label="Skills">
        <div class="container">
          <h2 class="section-heading">
            <span class="section-number">05</span>
            Skills
          </h2>
          <div class="skills-grid">
            {skills.languages && skills.languages.length > 0 && (
              <div class="skill-group">
                <h3>Languages</h3>
                <div class="skill-tags">
                  {skills.languages.map((s: string) => <span class="tag tag-lang">{s}</span>)}
                </div>
              </div>
            )}
            {skills.mlAi && skills.mlAi.length > 0 && (
              <div class="skill-group">
                <h3>ML / AI</h3>
                <div class="skill-tags">
                  {skills.mlAi.map((s: string) => <span class="tag tag-ml">{s}</span>)}
                </div>
              </div>
            )}
            {skills.cloudDevops && skills.cloudDevops.length > 0 && (
              <div class="skill-group">
                <h3>Cloud & DevOps</h3>
                <div class="skill-tags">
                  {skills.cloudDevops.map((s: string) => <span class="tag tag-cloud">{s}</span>)}
                </div>
              </div>
            )}
            {skills.frontend && skills.frontend.length > 0 && (
              <div class="skill-group">
                <h3>Frontend</h3>
                <div class="skill-tags">
                  {skills.frontend.map((s: string) => <span class="tag tag-fe">{s}</span>)}
                </div>
              </div>
            )}
            {skills.backend && skills.backend.length > 0 && (
              <div class="skill-group">
                <h3>Backend</h3>
                <div class="skill-tags">
                  {skills.backend.map((s: string) => <span class="tag tag-be">{s}</span>)}
                </div>
              </div>
            )}
            {skills.databases && skills.databases.length > 0 && (
              <div class="skill-group">
                <h3>Databases</h3>
                <div class="skill-tags">
                  {skills.databases.map((s: string) => <span class="tag tag-db">{s}</span>)}
                </div>
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- Awards Section -->
    {awards && awards.length > 0 && (
      <section id="awards" class="section section-alt" aria-label="Awards and honors">
        <div class="container">
          <h2 class="section-heading">
            <span class="section-number">06</span>
            Awards & Honors
          </h2>
          <div class="awards-grid">
            {awards.map((award) => (
              <div class="award-card">
                <span class="award-icon" aria-hidden="true">{award.icon || '🏆'}</span>
                <div>
                  <h3>{award.title}</h3>
                  <p class="award-meta">{award.awarder} · {fmtYearMonth(award.date) || award.date}</p>
                  <p class="award-summary">{award.summary}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Certifications Section -->
    {certificates && certificates.length > 0 && (
      <section id="certifications" class="section" aria-label="Certifications">
        <div class="container">
          <h2 class="section-heading">
            <span class="section-number">07</span>
            Certifications
          </h2>
          <div class="certs-grid">
            {certificates.map((cert) => (
              <div class="cert-card">
                <span class="cert-issuer">{cert.issuer}</span>
                <h3>{cert.name}</h3>
                <div class="cert-footer">
                  <span class="cert-year">{fmtYearMonth(cert.date) || cert.date}</span>
                  {cert.url && (
                    <a href={cert.url} target="_blank" rel="noopener noreferrer" class="cert-link">
                      View →
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Open Source Organizations Section -->
    <section id="open-source" class="section section-alt section-orgs" aria-label="Open source organizations">
      <div class="container">
        <h2 class="section-heading">
          <span class="section-number">08</span>
          Open Source Initiatives
        </h2>
        <p class="section-intro">
          Beyond individual contributions, I co-founded and lead two open-source organizations creating lasting impact in education and community technology.
        </p>
        <div class="orgs-grid">
          {orgs.map((org) => {
            const meta = ORG_DESCRIPTIONS[org.login];
            return (
              <article class="org-card">
                <div class="org-header">
                  <img
                    src={org.avatar_url}
                    alt={`${org.login} organization logo`}
                    class="org-avatar"
                    loading="lazy"
                    width="64"
                    height="64"
                  />
                  <div class="org-title">
                    <h3>{org.login}</h3>
                    {meta && <p class="org-tagline">{meta.tagline}</p>}
                  </div>
                </div>
                {meta && <p class="org-description">{meta.description}</p>}
                {meta && meta.highlights.length > 0 && (
                  <ul class="org-highlights">
                    {meta.highlights.map((h: string) => (
                      <li>
                        <span class="org-highlight-dot" aria-hidden="true">✦</span>
                        {h}
                      </li>
                    ))}
                  </ul>
                )}
                <div class="org-links">
                  <a
                    href={org.html_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="org-link org-link-github"
                  >
                    GitHub Organization →
                  </a>
                  <a
                    href={org.pagesUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="org-link org-link-web"
                  >
                    Website →
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Projects Section (from GitHub API) -->
    <section id="projects" class="section" aria-label="Projects">
      <div class="container">
        <h2 class="section-heading">
          <span class="section-number">09</span>
          Projects
        </h2>
        <p class="section-intro">
          All public repositories from my{' '}
          <a href={`https://github.com/${GITHUB_USER}`} target="_blank" rel="noopener noreferrer" class="inline-link">GitHub profile</a>,
          sorted by most recently updated.
        </p>
        {repos.length > 0 ? (
          <div class="projects-grid">
            {repos.map((repo) => {
              const year = new Date(repo.updated_at).getFullYear();
              const displayName = repo.name
                .replace(/-/g, ' ')
                .replace(/_/g, ' ')
                .replace(/\b\w/g, (c: string) => c.toUpperCase());
              return (
                <article class="project-card">
                  <div class="project-image">
                    <img
                      src={repo.socialPreviewUrl}
                      alt={`${displayName} preview`}
                      loading="lazy"
                      width="600"
                      height="314"
                    />
                  </div>
                  <div class="project-content">
                    <div class="project-top">
                      <h3>{displayName}</h3>
                      <span class="project-year">{year}</span>
                    </div>
                    {repo.description && <p class="project-desc">{repo.description}</p>}
                    {repo.topics && repo.topics.length > 0 && (
                      <div class="project-tags">
                        {repo.topics.slice(0, 5).map((t: string) => (
                          <span class="tag">{t}</span>
                        ))}
                      </div>
                    )}
                    <div class="project-links">
                      <a
                        href={repo.html_url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="project-link project-link-code"
                      >
                        View Code
                      </a>
                      <a
                        href={repo.pagesUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="project-link project-link-demo"
                      >
                        Live Demo
                      </a>
                    </div>
                    {(repo.language || repo.stargazers_count > 0) && (
                      <div class="project-stats">
                        {repo.language && <span class="repo-lang">{repo.language}</span>}
                        {repo.stargazers_count > 0 && (
                          <span class="repo-stars">⭐ {repo.stargazers_count}</span>
                        )}
                      </div>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <p class="empty-state">Projects loading from GitHub...</p>
        )}
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="footer-inner">
        <div class="footer-links">
          {basics.profiles.map((p) => (
            <a href={p.url} target="_blank" rel="noopener noreferrer">{p.network}</a>
          ))}
          <a href={`mailto:${basics.email}`}>{basics.email}</a>
        </div>
        <p class="footer-credit">Made with ❤️ by {basics.name}</p>
        <p class="footer-location">Bogotá, Colombia 🇨🇴</p>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0.9rem 0;
    transition: background 0.3s;
  }
  .nav.scrolled {
    background: rgba(10, 10, 15, 0.98);
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .nav-logo {
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--accent-primary);
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .nav-links {
    display: flex;
    gap: 1.75rem;
    align-items: center;
  }
  .nav-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent-primary);
    transition: width 0.2s;
  }
  .nav-links a:hover { color: var(--text-primary); }
  .nav-links a:hover::after { width: 100%; }
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all 0.3s;
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .hero-greeting {
    color: var(--accent-secondary);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }
  .hero-name {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    background: linear-gradient(135deg, var(--text-primary) 30%, var(--accent-primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }
  .hero-roles {
    font-size: 1.25rem;
    color: var(--accent-secondary);
    margin-bottom: 1.5rem;
    min-height: 2rem;
    font-weight: 500;
  }
  .typewriter::after {
    content: '|';
    animation: blink 1s step-end infinite;
    color: var(--accent-primary);
  }
  @keyframes blink { 50% { opacity: 0; } }
  .hero-description {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 560px;
    margin-bottom: 2rem;
    line-height: 1.8;
  }
  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .hero-social {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .hero-social-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .hero-social-link:hover {
    color: var(--accent-primary);
